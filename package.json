{
  "name": "dmytrotuzov-portfolio",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "pnpm run build && wrangler dev",
    "typecheck": "astro check && tsc --noEmit",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "eslint \"src/**/*.{ts,vue}\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" --fix --no-error-on-unmatched-pattern",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/vue": "^6.0.1",
    "astro": "^6.3.3",
    "vue": "^3.5.13"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^3.1.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.27.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "sass": "^1.88.0",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4",
    "vue-eslint-parser": "^10.4.0",
    "wrangler": "^4.93.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
