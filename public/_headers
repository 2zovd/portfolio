/*
  # ─── Security Headers — dmytrotuzov.dev ─────────────────────────────────────
  # Deployed on Cloudflare Pages. CF edge handles DDoS and rate limiting.

  # Prevents clickjacking (belt-and-suspenders alongside frame-ancestors in CSP)
  X-Frame-Options: DENY

  # Prevents MIME-type sniffing attacks
  X-Content-Type-Options: nosniff

  # Controls the Referer header sent on cross-origin requests
  Referrer-Policy: strict-origin-when-cross-origin

  # Restricts access to browser feature APIs
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Forces HTTPS for 1 year; eligible for browser HSTS preload list
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # ─── Content Security Policy ──────────────────────────────────────────────────
  # 'unsafe-inline' for script-src: required for Astro's inline theme-flash
  # prevention script (<script is:inline>) and JSON-LD schema tag. This is a
  # fully static SSG site with no user-generated content — XSS risk is accepted.
  #
  # challenges.cloudflare.com: Cloudflare Turnstile widget (contact form, EPIC-03).
  # Fonts are self-hosted via @fontsource — no external font origins needed.
  # base-uri 'self': prevents base-tag injection attacks.
  # form-action 'self': contact form may only POST to the same origin.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' data: https://challenges.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https:; connect-src 'self' https://challenges.cloudflare.com https://cloudflareinsights.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
