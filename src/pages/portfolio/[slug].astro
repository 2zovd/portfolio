---
import { getCollection, render } from 'astro:content';
import PageLayout from '@app/layouts/PageLayout.astro';
import PostMeta from '@shared/ui/PostMeta.astro';
import { formatISO } from '@shared/lib/formatDate';
import { SITE } from '@shared/config/site';

export async function getStaticPaths() {
  const projects = await getCollection('portfolio');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, date, tags, links } = project.data;

const ogImage = project.data.cover ?? `/og/project/${project.id}.png`;

const pageSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: title,
  description: description,
  datePublished: formatISO(date),
  author: { '@type': 'Person', name: SITE.name, url: SITE.url },
  url: new URL(`/portfolio/${project.id}`, SITE.url).href,
};

const actionLinks = [
  links.live ? { href: links.live, label: 'Live site', external: true } : null,
  links.repo ? { href: links.repo, label: 'Repository', external: true } : null,
  links.case ? { href: links.case, label: 'Case study', external: true } : null,
].filter(Boolean) as { href: string; label: string; external: boolean }[];
---

<PageLayout
  title={`${title} · ${SITE.name}`}
  description={description}
  ogImage={ogImage}
  pageSchema={pageSchema}
>
  <article class="project-layout">
    <a href="/portfolio" class="project-layout__back">← Work</a>

    <header class="project-layout__header">
      <PostMeta pubDate={date} tags={tags} />

      <h1 class="project-layout__title">{title}</h1>
      <p class="project-layout__desc">{description}</p>

      {actionLinks.length > 0 && (
        <nav class="project-layout__links" aria-label="Project links">
          {actionLinks.map((link) => (
            <a
              href={link.href}
              class="project-layout__link"
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
            >
              {link.label}
              {link.external && (
                <span aria-hidden="true"> ↗</span>
              )}
            </a>
          ))}
        </nav>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</PageLayout>

<style lang="scss">
  .project-layout {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-24) var(--space-6);
  }

  .project-layout__back {
    display: inline-block;
    margin-bottom: var(--space-8);
    font-size: var(--font-size-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition-fast);

    &:hover {
      color: var(--color-text);
    }
  }

  .project-layout__header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .project-layout__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }

  .project-layout__date {
    font-size: var(--font-size-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-subtle);
    white-space: nowrap;
  }

  .project-layout__sep {
    color: var(--color-border-hover);
  }

  .project-layout__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .project-layout__title {
    font-size: var(--font-size-6xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--color-text);
    margin-bottom: var(--space-4);

    @media (max-width: #{$bp-md - 1px}) {
      font-size: var(--font-size-4xl);
    }
  }

  .project-layout__desc {
    font-size: var(--font-size-lg);
    line-height: 1.6;
    color: var(--color-muted);
    margin-bottom: var(--space-5);
  }

  .project-layout__links {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .project-layout__link {
    font-size: var(--font-size-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent);
    padding-bottom: 1px;
    transition: color var(--transition-fast), border-color var(--transition-fast);

    &:hover {
      color: var(--color-accent-hover);
      border-color: var(--color-accent-hover);
    }
  }
</style>
