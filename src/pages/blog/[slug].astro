---
import { getCollection, render } from 'astro:content';
import PageLayout from '@app/layouts/PageLayout.astro';
import PostMeta from '@shared/ui/PostMeta.astro';
import { formatISO } from '@shared/lib/formatDate';
import { readingTime } from '@shared/lib/readingTime';
import { SITE } from '@shared/config/site';
import { CodeCopy } from '@features/CodeCopy';
import { ReadingProgress } from '@features/ReadingProgress';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, tags } = post.data;

const ogImage = post.data.cover ?? `/og/blog/${post.id}.png`;
const postReadingTime = post.body ? readingTime(post.body) : undefined;

const pageSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: formatISO(pubDate),
  author: { '@type': 'Person', name: SITE.name, url: SITE.url },
  publisher: { '@type': 'Person', name: SITE.name, url: SITE.url },
  url: new URL(`/blog/${post.id}`, SITE.url).href,
  image: new URL(ogImage, SITE.url).href,
};
---

<PageLayout
  title={`${title} · ${SITE.name}`}
  description={description}
  ogImage={ogImage}
  pageSchema={pageSchema}
>
  <ReadingProgress client:load />
  <article class="post-layout">
    <CodeCopy client:load />
    <a href="/blog" class="post-layout__back">← Blog</a>

    <header class="post-layout__header">
      <PostMeta pubDate={pubDate} tags={tags} readingTime={postReadingTime} />

      <h1 class="post-layout__title">{title}</h1>
      <p class="post-layout__desc">{description}</p>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</PageLayout>

<style lang="scss">
  .post-layout {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-24) var(--space-6);
  }

  .post-layout__back {
    display: inline-block;
    margin-bottom: var(--space-8);
    font-size: var(--font-size-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1px;
    transition: color var(--transition-fast), border-color var(--transition-fast);

    &:hover {
      color: var(--color-text);
      border-color: var(--color-border-hover);
    }
  }

  .post-layout__reading-time {
    font-size: var(--font-size-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-subtle);
    white-space: nowrap;
  }

  .post-layout__header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .post-layout__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }

  .post-layout__date {
    font-size: var(--font-size-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-subtle);
    white-space: nowrap;
  }

  .post-layout__sep {
    color: var(--color-border-hover);
  }

  .post-layout__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .post-layout__title {
    font-size: var(--font-size-6xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--color-text);
    margin-bottom: var(--space-4);

    @media (max-width: #{$bp-md - 1px}) {
      font-size: var(--font-size-4xl);
    }
  }

  .post-layout__desc {
    font-size: var(--font-size-lg);
    line-height: 1.6;
    color: var(--color-muted);
  }
</style>
