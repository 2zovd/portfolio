---
import PageLayout from '@app/layouts/PageLayout.astro';
import { SITE } from '@shared/config/site';
---

<PageLayout
  title={`Blog · ${SITE.name}`}
  description="Articles on frontend engineering, Vue 3, TypeScript, and architecture."
>
  <section style="max-width: 1200px; margin: 0 auto; padding: var(--space-24) var(--space-6);">
    <h1 class="text-section">Blog</h1>
    <p style="margin-top: var(--space-6); color: var(--color-muted);">Coming soon.</p>
  </section>
</PageLayout>
