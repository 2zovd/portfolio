---
import PageLayout from '@app/layouts/PageLayout.astro';
import { SITE } from '@shared/config/site';
---

<PageLayout
  title={`Contact · ${SITE.name}`}
  description="Get in touch with Dmytro Tuzov — Frontend Engineer available for new opportunities."
>
  <section class="contact-stub" aria-labelledby="contact-heading">
    <div class="contact-stub__container">
      <p class="contact-stub__label">Contact</p>
      <h1 id="contact-heading" class="contact-stub__heading">
        Let's work together.
      </h1>
      <p class="contact-stub__text">
        I'm currently available for new opportunities — full-time, contract, or consulting.
        The best way to reach me is by email.
      </p>
      <a
        href={`mailto:${SITE.email}`}
        class="contact-stub__email"
      >
        {SITE.email}
      </a>

      <div class="contact-stub__socials">
        {SITE.socials.map((social) => (
          <a
            href={social.href}
            class="contact-stub__social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.label}
          >
            {social.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .contact-stub {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-24) var(--space-6);
  }

  .contact-stub__container {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .contact-stub__label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .contact-stub__heading {
    font-size: 40px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--color-text);

    @media (max-width: 767px) {
      font-size: 28px;
    }
  }

  .contact-stub__text {
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 52ch;
  }

  .contact-stub__email {
    display: inline-block;
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent);
    padding-bottom: 2px;
    transition: color var(--transition-fast), border-color var(--transition-fast);

    &:hover {
      color: var(--color-accent);
    }
  }

  .contact-stub__socials {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .contact-stub__social-link {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition-fast);

    &:hover {
      color: var(--color-text);
    }
  }
</style>
