---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}

const { title, subtitle, id } = Astro.props;
---

<div class="section-heading">
  <h2 id={id} class="section-heading__title">{title}</h2>
  {subtitle && <p class="section-heading__subtitle">{subtitle}</p>}
</div>

<style>
  .section-heading {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-12);
  }

  .section-heading__title {
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text);
  }

  .section-heading__subtitle {
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-muted);
  }
</style>
