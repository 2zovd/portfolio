---
import { Image } from 'astro:assets';
import { SITE } from '@shared/config/site';
import SectionHeading from '@shared/ui/SectionHeading.astro';
import Tag from '@shared/ui/Tag.astro';
import photo from '../../assets/photo.png';
import styles from './About.module.scss';

const skills = [
  {
    category: 'Core',
    items: ['JavaScript', 'TypeScript', 'Vue 3', 'Pinia', 'Vuex'],
  },
  {
    category: 'Architecture',
    items: ['Microfrontends', 'Backbone.js', 'Vite UMD', 'Event Bus'],
  },
  {
    category: 'Tooling',
    items: ['Vite', 'Webpack', 'Vitest', 'GitLab CI/CD'],
  },
  {
    category: 'Platform',
    items: ['Cordova', 'REST APIs', 'i18n', 'Figma'],
  },
];

const experience = [
  {
    company: 'Libertex Group',
    role: 'Frontend Engineer',
    period: 'Oct 2018 — Present',
    location: 'Remote · Cyprus',
    highlights: [
      'Architected Vue 3 / TypeScript / Pinia microfrontend delivering AI-generated trading signals to 3M+ platform users',
      'Delivered a Vue 3 / Vuex 4 microfrontend targeting web, iOS, and Android via Cordova',
      'Integrated microfrontends with legacy Backbone.js / Marionette host via EventBus (JWT lifecycle, real-time data)',
      'Drove JS→TS and Vuex→Pinia modernization across the Vue 3 stack; led code reviews in an 8-person cross-functional team',
    ],
  },
  {
    company: 'Mobilsoft',
    role: 'UI Developer',
    period: 'Feb 2017 — Mar 2018',
    location: 'Remote',
    highlights: [
      'Built responsive, accessible UIs for an iGaming platform with optimised animation and cross-device compatibility',
      'Enhanced Laravel-based applications on the frontend side',
    ],
  },
  {
    company: 'Contract & Freelance',
    role: 'Frontend Developer',
    period: 'Dec 2015 — Jun 2018',
    location: 'Remote',
    highlights: [
      'Built complete frontend for a social platform (desktop + mobile web) from scratch — remains in production today',
      'Delivered responsive sites and a learning platform for international clients via Upwork',
    ],
  },
];
---

<section class={styles.about} aria-labelledby="about-heading">
  <div class={styles.container}>
    <SectionHeading
      id="about-heading"
      title="About"
      subtitle="Frontend Engineer with 7+ years shipping production-grade interfaces."
    />

    <div class={styles.grid}>

      <!-- Left: bio + skills -->
      <div class={styles.left}>
        <div class={styles.about__photo_wrap}>
          <Image
            src={photo}
            alt="Dmytro Tuzov — Frontend Engineer"
            class={styles.about__photo}
            loading="lazy"
          />
        </div>
        <div class={styles.bio}>
          <p class={styles.bio__text}>
            Frontend Engineer based in {SITE.location}, specialising in hybrid legacy/modern
            architectures for fintech trading platforms. For 7+ years I've been shipping
            production features at Libertex Group — products used by 3M+ traders across
            120+ countries.
          </p>
          <p class={styles.bio__text}>
            I work across Backbone.js / Marionette legacy stacks and Vue 3 microfrontend
            architectures within the same production system. I care about clean component
            boundaries, strict typing, and hands-on modernization — and I use AI tooling
            (Claude Code, GitHub Copilot) as part of my daily workflow.
          </p>
        </div>

        <div class={styles.skills}>
          <h3 class={styles.skills__heading}>Skills</h3>
          <div class={styles.skills__grid}>
            {skills.map((group) => (
              <div class={styles.skills__group}>
                <span class={styles.skills__category}>{group.category}</span>
                <div class={styles.skills__tags}>
                  {group.items.map((item) => (
                    <Tag label={item} />
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: experience timeline -->
      <div class={styles.right}>
        <h3 class={styles.timeline__heading}>Experience</h3>
        <ol class={styles.timeline} role="list">
          {experience.map((job, i) => (
            <li class={styles.timeline__item}>
              <div class={styles.timeline__marker} aria-hidden="true">
                <span class={styles.timeline__dot} />
                {i < experience.length - 1 && <span class={styles.timeline__line} />}
              </div>
              <div class={styles.timeline__content}>
                <div class={styles.timeline__header}>
                  <span class={styles.timeline__company}>{job.company}</span>
                  <span class={styles.timeline__period}>{job.period}</span>
                </div>
                <span class={styles.timeline__role}>{job.role}</span>
                <span class={styles.timeline__location}>{job.location}</span>
                <ul class={styles.timeline__highlights} role="list">
                  {job.highlights.map((h) => (
                    <li class={styles.timeline__highlight}>{h}</li>
                  ))}
                </ul>
              </div>
            </li>
          ))}
        </ol>
      </div>

    </div>
  </div>
</section>
