---
import { SITE } from '@shared/config/site';
import SectionHeading from '@shared/ui/SectionHeading.astro';
import Tag from '@shared/ui/Tag.astro';
import styles from './About.module.scss';

const skills = [
  {
    category: 'Languages',
    items: ['JavaScript', 'TypeScript', 'HTML', 'CSS / SCSS'],
  },
  {
    category: 'Frameworks',
    items: ['Vue 3', 'Pinia', 'Vuex', 'Astro', 'Backbone.js'],
  },
  {
    category: 'Tools',
    items: ['Vite', 'Webpack', 'Vitest', 'ESLint', 'Git'],
  },
  {
    category: 'Platforms',
    items: ['Cloudflare Pages', 'Cordova', 'Node.js', 'Docker'],
  },
];

const experience = [
  {
    company: 'Libertex Group',
    role: 'Senior Frontend Engineer',
    period: '2017 — Present',
    location: 'Remote · Cyprus',
    highlights: [
      'Led migration from Backbone.js to Vue 3 micro-frontend architecture across a 3M+ user fintech platform',
      'Architected shared component library consumed by 6 product teams',
      'Reduced initial bundle size by 40% through code-splitting and lazy loading',
      'Mentored 4 junior engineers, conducted 200+ code reviews',
    ],
  },
  {
    company: 'Freelance',
    role: 'Frontend Developer',
    period: '2015 — 2017',
    location: 'Remote',
    highlights: [
      'Built SPAs and landing pages for clients across e-commerce and media',
      'Stack: vanilla JavaScript, jQuery, SCSS, WordPress',
    ],
  },
];
---

<section class={styles.about} aria-labelledby="about-heading">
  <div class={styles.container}>
    <SectionHeading
      id="about-heading"
      title="About"
      subtitle={`Frontend Engineer with ${7}+ years shipping production-grade interfaces.`}
    />

    <div class={styles.grid}>

      <!-- Left: bio + skills -->
      <div class={styles.left}>
        <div class={styles.bio}>
          <p class={styles.bio__text}>
            I'm a Frontend Engineer based in {SITE.location}, specialising in Vue 3,
            TypeScript, and large-scale micro-frontend architectures. For the past 7+ years
            I've been building trading platforms at Libertex Group — products used by
            millions of traders worldwide.
          </p>
          <p class={styles.bio__text}>
            I care about code that scales: clean component boundaries, strict typing, and
            automated quality gates. Outside of product work I contribute to open-source,
            write technical articles, and speak at local meetups.
          </p>
        </div>

        <div class={styles.skills}>
          <h3 class={styles.skills__heading}>Skills</h3>
          <div class={styles.skills__grid}>
            {skills.map((group) => (
              <div class={styles.skills__group}>
                <span class={styles.skills__category}>{group.category}</span>
                <div class={styles.skills__tags}>
                  {group.items.map((item) => (
                    <Tag label={item} />
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: experience timeline -->
      <div class={styles.right}>
        <h3 class={styles.timeline__heading}>Experience</h3>
        <ol class={styles.timeline} role="list">
          {experience.map((job, i) => (
            <li class={styles.timeline__item}>
              <div class={styles.timeline__marker} aria-hidden="true">
                <span class={styles.timeline__dot} />
                {i < experience.length - 1 && <span class={styles.timeline__line} />}
              </div>
              <div class={styles.timeline__content}>
                <div class={styles.timeline__header}>
                  <span class={styles.timeline__company}>{job.company}</span>
                  <span class={styles.timeline__period}>{job.period}</span>
                </div>
                <span class={styles.timeline__role}>{job.role}</span>
                <span class={styles.timeline__location}>{job.location}</span>
                <ul class={styles.timeline__highlights} role="list">
                  {job.highlights.map((h) => (
                    <li class={styles.timeline__highlight}>{h}</li>
                  ))}
                </ul>
              </div>
            </li>
          ))}
        </ol>
      </div>

    </div>
  </div>
</section>
