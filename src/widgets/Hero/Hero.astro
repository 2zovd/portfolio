---
import { Image } from 'astro:assets';
import { SITE } from '@shared/config/site';
import { TimeDisplay } from '@features/TimeDisplay';
import { HeroCanvas } from '@features/HeroCanvas';
import photo from '../../assets/photo.png';
import styles from './Hero.module.scss';

const tags = ['Vue 3', 'TypeScript', 'Fintech', 'Microfrontends'];
const stack = [
  'JavaScript', 'TypeScript', 'Vue 3', 'Pinia', 'Vuex', 'Astro',
  'Backbone.js', 'Vite', 'Webpack', 'SCSS', 'Vitest', 'Cordova',
];
---

<section class={styles.hero} aria-labelledby="hero-heading">
  <HeroCanvas client:load />
  <div class={styles.hero__grid}>

    <!-- Left column -->
    <div class={styles.hero__left}>
      <div class={styles.hero__photo_wrap}>
        <Image
          src={photo}
          alt="Dmytro Tuzov — Frontend Engineer"
          class={styles.hero__photo}
          loading="eager"
          fetchpriority="high"
        />
      </div>

      <div class={styles.tags} aria-label="Specializations">
        {tags.map((t) => <span class={styles.tag}>{t}</span>)}
      </div>

      <h1 id="hero-heading" class={styles.heading}>
        {SITE.name}
      </h1>

      <p class={styles.description}>
        Frontend Engineer specialising in hybrid legacy/modern architectures for fintech
        trading platforms. 7+ years shipping production features in Vue 3, TypeScript, and
        Backbone.js stacks — serving 3M+ users across 120+ countries.
      </p>

      <div class={styles.cta}>
        <a href="/portfolio" class={`${styles.btn} ${styles['btn--primary']}`}>
          View Work
        </a>
        <a href="/cv/dmytro-tuzov-cv.pdf" class={`${styles.btn} ${styles['btn--secondary']}`}>
          Download CV
        </a>
      </div>
    </div>

    <!-- Right column -->
    <div class={styles.hero__right}>
      <!-- Terminal card -->
      <div class={styles.terminal} aria-label="Terminal output">
        <div class={styles.terminal__bar}>
          <span class={styles.terminal__dot} aria-hidden="true" />
          <span class={styles.terminal__dot} aria-hidden="true" />
          <span class={styles.terminal__dot} aria-hidden="true" />
          <span class={styles.terminal__title}>dmytro@dev:~</span>
        </div>
        <pre class={styles.terminal__body} aria-label="About me in terminal format"><code><span class={styles.terminal__prompt}>$</span> whoami
<span class={styles.terminal__value}>{SITE.name}</span>

<span class={styles.terminal__prompt}>$</span> location
<span class={styles.terminal__value}>{SITE.location}</span>

<span class={styles.terminal__prompt}>$</span> experience
<span class={styles.terminal__value}>7+ years · fintech</span>

<span class={styles.terminal__prompt}>$</span> stack
<span class={styles.terminal__value}>Vue 3 · TypeScript · Astro</span>

<span class={styles.terminal__prompt}>$</span> <span class={styles.terminal__cursor} aria-hidden="true" /></code></pre>
      </div>

      <!-- Contact / availability card -->
      <div class={styles.contact}>
        <div class={styles.contact__status}>
          <span class={styles.contact__dot} aria-hidden="true" />
          <span>Let's connect</span>
        </div>
        <a href="/contact" class={styles.contact__email}>
          Get in touch
        </a>
        <TimeDisplay client:load />
      </div>
    </div>
  </div>
</section>

<!-- Stack bar -->
<div class={styles.stack} aria-label="Technology stack">
  <div class={styles.stack__scroll}>
    {stack.map((t) => <span class={styles.stack__tag}>{t}</span>)}
  </div>
</div>
