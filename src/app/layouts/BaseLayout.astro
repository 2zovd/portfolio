---
import { ClientRouter } from 'astro:transitions';
import { SITE } from '@shared/config/site';
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono/400.css';
import jbMonoUrl from '@fontsource/jetbrains-mono/files/jetbrains-mono-latin-400-normal.woff2?url';
import '../styles/global.scss';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  schema?: boolean;
  pageSchema?: Record<string, unknown>;
}

const {
  title,
  description = SITE.description,
  ogImage = '/og.png',
  canonical,
  schema = false,
  pageSchema,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, SITE.url).href;
const ogImageURL = new URL(ogImage, SITE.url).href;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  url: SITE.url,
  jobTitle: SITE.role,
  address: { '@type': 'PostalAddress', addressCountry: 'ME' },
  sameAs: SITE.socials.map((s) => s.href),
};
---

<!doctype html>
<html lang="en">
  <head>
    {/* Theme flash prevention — must be the very first script, before any CSS or font */}
    <script is:inline>
      (function () {
        function applyTheme() {
          var stored = localStorage.getItem('theme');
          if (stored === 'light') {
            document.documentElement.classList.add('light');
          } else {
            document.documentElement.classList.remove('light');
          }
        }
        applyTheme();
        // Re-apply after Astro View Transitions swaps the body
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    {/* SEO */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={SITE.name} />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {/* Favicon */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Preload terminal/code-block font to avoid LCP delay on font swap */}
    <link rel="preload" as="font" type="font/woff2" href={jbMonoUrl} crossorigin />

    {/* JSON-LD Person schema — homepage only */}
    {schema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    )}

    {/* JSON-LD page-specific schema — blog posts, projects */}
    {pageSchema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(pageSchema).replace(/</g, '\\u003c')} />
    )}

    <slot name="head" />

    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
